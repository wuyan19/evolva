{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Evolva",
  "version": "0.2.1",
  "identifier": "com.evolva.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Evolva",
        "width": 1280,
        "height": 800,
        "center": true,
        "resizable": true,
        "minWidth": 400,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "exe", "dmg", "app", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
